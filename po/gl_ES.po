#: lutris/runners/web.py:19 lutris/runners/web.py:21
msgid "Web"
msgstr "Web"

#: lutris/runners/web.py:20
msgid "Runs web based games"
msgstr "Executa xogos baseados na web"

#: lutris/runners/web.py:26
msgid "Full URL or HTML file path"
msgstr "URL completa ou roteiro do arquivo HTML"

#: lutris/runners/web.py:27
msgid "The full address of the game's web page or path to a HTML file."
msgstr ""
"A dirección completa da páxina web do xogo ou o roteiro a un arquivo HTML."

#: lutris/runners/web.py:33
msgid "Open in fullscreen"
msgstr "Abrir en pantalla completa"

#: lutris/runners/web.py:36
msgid "Launch the game in fullscreen."
msgstr "Inicia o xogo en pantalla completa."

#: lutris/runners/web.py:40
msgid "Open window maximized"
msgstr "Abrir xanela maximizada"

#: lutris/runners/web.py:43
msgid "Maximizes the window when game starts."
msgstr "Maximiza a xanela cando se inicia o xogo."

#: lutris/runners/web.py:58
msgid "The initial size of the game window when not opened."
msgstr "O tamaño inicial da xanela do xogo cando non se abre."

#: lutris/runners/web.py:62
msgid "Disable window resizing (disables fullscreen and maximize)"
msgstr ""
"Desactivar o cambio de tamaño das xanelas (desactiva a pantalla completa e a "
"maximización)"

#: lutris/runners/web.py:65
msgid "You can't resize this window."
msgstr "Non se pode cambiar o tamaño desta xanela."

#: lutris/runners/web.py:69
msgid "Borderless window"
msgstr "Xanela sen bordos"

#: lutris/runners/web.py:72
msgid "The window has no borders/frame."
msgstr "A xanela non ten bordos/marco."

#: lutris/runners/web.py:76
msgid "Disable menu bar and default shortcuts"
msgstr "Desactivar a barra de menús e os accesos directos predeterminados"

#: lutris/runners/web.py:79
msgid ""
"This also disables default keyboard shortcuts, like copy/paste and "
"fullscreen toggling."
msgstr ""
"Isto tamén desactiva os atallos de teclado predeterminados, como copiar/"
"pegar e cambiar pantalla completa."

#: lutris/runners/web.py:83
msgid "Disable page scrolling and hide scrollbars"
msgstr ""
"Desactivar o desprazamento da páxina e ocultar as barras de desprazamento"

#: lutris/runners/web.py:86
msgid "Disables scrolling on the page."
msgstr "Desactiva o desprazamento na páxina."

#: lutris/runners/web.py:90
msgid "Hide mouse cursor"
msgstr "Ocultar o cursor do rato"

#: lutris/runners/web.py:93
msgid "Prevents the mouse cursor from showing when hovering above the window."
msgstr "Evita que se mostre o cursor do rato ao pasar por encima da xanela."

#: lutris/runners/web.py:97
msgid "Open links in game window"
msgstr "Abrir ligazóns na xanela do xogo"

#: lutris/runners/web.py:101
msgid ""
"Enable this option if you want clicked links to open inside the game window. "
"By default all links open in your default web browser."
msgstr ""
"Active esta opción se quere cas ligazóns nas que se fai clic ábranse dentro "
"da xanela do xogo. Por defecto, todas as ligazóns ábrense no seu navegador "
"web predeterminado."

#: lutris/runners/web.py:107
msgid "Remove default <body> margin & padding"
msgstr "Eliminar a marxe e o recheo predeterminado de <body>"

#: lutris/runners/web.py:110
msgid ""
"Sets margin and padding to zero on &lt;html&gt; and &lt;body&gt; elements."
msgstr ""
"Establece a marxe e o recheo a cero nos elementos &lt;html&gt; y "
"&lt;body&gt;."

#: lutris/runners/web.py:114
msgid "Enable Adobe Flash Player"
msgstr "Activar Adobe Flash Player"

#: lutris/runners/web.py:117
msgid "Enable Adobe Flash Player."
msgstr "Activar Adobe Flash Player."

#: lutris/runners/web.py:121
msgid "Custom User-Agent"
msgstr "Axente de usuario personalizado"

#: lutris/runners/web.py:124
msgid "Overrides the default User-Agent header used by the runner."
msgstr ""
"Anula a cabeceira de axente usuario predeterminada utilizada polo executor."

#: lutris/runners/web.py:129
msgid "Debug with Developer Tools"
msgstr "Depurar con ferramentas para desenvolvedores"

#: lutris/runners/web.py:132
msgid "Let's you debug the page."
msgstr "Permite depurar a páxina."

#: lutris/runners/web.py:137
msgid "Open in web browser (old behavior)"
msgstr "Abrir no navegador web (comportamento anterior)"

#: lutris/runners/web.py:140
msgid "Launch the game in a web browser."
msgstr "Inicia o xogo nun navegador web."

#: lutris/runners/web.py:144
msgid "Custom web browser executable"
msgstr "Executable do navegador web personalizado"

#: lutris/runners/web.py:147
msgid ""
"Select the executable of a browser on your system.\n"
"If left blank, Lutris will launch your default browser (xdg-open)."
msgstr ""
"Escolla o executable dun navegador no seu sistema.\n"
"Se se deixa en branco, Lutris iniciará o seu navegador predeterminado (xdg-"
"open)."

#: lutris/runners/web.py:153
msgid "Web browser arguments"
msgstr "Argumentos do navegador web"

#: lutris/runners/web.py:157
msgid ""
"Command line arguments to pass to the executable.\n"
"$GAME or $URL inserts the game url.\n"
"\n"
"For Chrome/Chromium app mode use: --app=\"$GAME\""
msgstr ""
"Argumentos da liña de comandos para pasar ao executable.\n"
"$GAME ou $URL insire a url do xogo.\n"
"\n"
"Para usar o modo de aplicación de Chrome/Chromium utilice: --app=\"$GAME\""

#: lutris/runners/web.py:176
msgid ""
"The web address is empty, \n"
"verify the game's configuration."
msgstr ""
"A dirección web está baleira, \n"
"comprobe a configuración do xogo."

#: lutris/runners/web.py:183
#, python-format
msgid ""
"The file %s does not exist, \n"
"verify the game's configuration."
msgstr ""
"O arquivo %s non existe, \n"
"comprobe a configuración do xogo."

#: lutris/runners/wine.py:97 lutris/runners/wine.py:866
msgid "Proton is not compatible with 32-bit prefixes."
msgstr "Proton non é compatible con prefixos de 32-bit."

#: lutris/runners/wine.py:111
msgid ""
"<b>Warning</b> Some Wine configuration options cannot be applied, if no "
"prefix can be found."
msgstr ""
"<b>Advertencia</b> Se non se atopa un prefixo, algunhas opcións de "
"configuración de Wine non poden aplicarse."

#: lutris/runners/wine.py:119
msgid "<b>Warning</b> No executable path specified"
msgstr "<b>Advertencia</b> Non se especificou un roteiro ao executable"

#: lutris/runners/wine.py:121
msgid ""
"<b>Warning</b> Executable path has extra whitespace at the beginning or end"
msgstr ""
"<b>Advertencia</b> O roteiro ao executable contén espazos en branco ao "
"comezo ou ao final"

#: lutris/runners/wine.py:132
msgid "<b>Warning</b> Executable file does not exist"
msgstr "<b>Advertencia</b> O arquivo executable non existe"

#: lutris/runners/wine.py:141
#, python-format
msgid ""
"<b>Warning</b> Your NVIDIA driver is outdated.\n"
"You are currently running driver %s which does not fully support all "
"features for Vulkan and DXVK games."
msgstr ""
"<b>Advertencia</b> O seu controlador de NVIDIA está obsoleto.\n"
"Actualmente está a utilizar o controlador %s que non soporta totalmente as "
"funcións para xogos Vulkan e DXVK."

#: lutris/runners/wine.py:154
#, python-format
msgid ""
"<b>Error</b> Vulkan is not installed or is not supported by your system, %s "
"is not available."
msgstr ""
"<b>Erro</b> Vulkan non está instalado ou o seu sistema non o soporta, %s non "
"está dispoñible."

#: lutris/runners/wine.py:169
#, python-format
msgid ""
"<b>Warning</b> Lutris has detected that Vulkan API version %s is installed, "
"but to use the latest DXVK version, %s is required."
msgstr ""
"<b>Advertencia</b> Lutris detectou a versión %s do API Vulkan instalada, "
"pero para usar a última versión de DXVK requírese %s."

#: lutris/runners/wine.py:177
#, python-format
msgid ""
"<b>Warning</b> Lutris has detected that the best device available ('%s') "
"supports Vulkan API %s, but to use the latest DXVK version, %s is required."
msgstr ""
"<b>Advertencia</b> Lutris detectou co mellor dispositivo dispoñible ('%s') "
"soporta Vulkan API %s, pero para usar a última versión de DXVK requírese %s."

#: lutris/runners/wine.py:193
msgid ""
"<b>Warning</b> Your limits are not set correctly. Please increase them as "
"described here:\n"
"<a href='https://github.com/lutris/docs/blob/master/HowToEsync.md'>How-to-"
"Esync (https://github.com/lutris/docs/blob/master/HowToEsync.md)</a>"
msgstr ""
"<b>Advertencia</b> Os seus límites non están correctamente configurados. "
"Aumentar tal e como se describe aquí:\n"
"<a href='https://github.com/lutris/docs/blob/master/HowToEsync.md'>Como-"
"Esync (https://github.com/lutris/docs/blob/master/HowToEsync.md)</a>"

#: lutris/runners/wine.py:204
msgid "<b>Warning</b> Your kernel is not patched for fsync."
msgstr "<b>Advertencia</b> O seu kernel non está parcheado para usar fsync."

#: lutris/runners/wine.py:209
msgid "Wine virtual desktop is no longer supported"
msgstr "Xa non se soporta o escritorio virtual de Wine"

#: lutris/runners/wine.py:215
msgid "Virtual desktops cannot be enabled in Proton or GE Wine versions."
msgstr ""
"Os escritorios virtuais non se poden activar nas versións de Wine Proton ou "
"GE."

#: lutris/runners/wine.py:228
msgid "You cannot use winewayland driver when using an X11-based session"
msgstr ""
"Non se pode usar o controlador winewayland cando se está usando unha sesión "
"baseada en X11"

#: lutris/runners/wine.py:232
msgid "Your Proton version does not support winewayland graphics driver"
msgstr ""
"A súa versión de Proton non soporta o controlador de gráficos winewayland"

#: lutris/runners/wine.py:234
msgid "Your Wine version does not support winewayland graphics driver"
msgstr ""
"A súa versión de Wine non soporta o controlador de gráficos winewayland"

#: lutris/runners/wine.py:240
msgid "Custom (select executable below)"
msgstr "Personalizado (escolla o executable a continuación)"


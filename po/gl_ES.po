#: share/applications/net.lutris.Lutris.desktop:2
#: share/metainfo/net.lutris.Lutris.metainfo.xml:13
#: share/lutris/ui/lutris-window.ui:25 lutris/gui/application.py:93
#: lutris/gui/config/accounts_box.py:26 lutris/gui/widgets/status_icon.py:102
#: lutris/services/lutris.py:50 lutris/sysoptions.py:107
#: lutris/sysoptions.py:117 lutris/sysoptions.py:129 lutris/sysoptions.py:137
#: lutris/sysoptions.py:151
msgid "Lutris"
msgstr "Lutris"

#: share/applications/net.lutris.Lutris.desktop:4
msgid "Video Game Preservation Platform"
msgstr "Plataforma de Preservación de Videoxogos"

#: share/applications/net.lutris.Lutris.desktop:6
msgid "gaming;wine;emulator;"
msgstr "xogo;wine;emulador;"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:8
#: share/metainfo/net.lutris.Lutris.metainfo.xml:10
msgid "Lutris Team"
msgstr "O equipo de Lutris"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:14
#: share/lutris/ui/about-dialog.ui:18
msgid "Video game preservation platform"
msgstr "Plataforma de preservación de videoxogos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:17
msgid "Main window"
msgstr "Xanela principal"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:21
msgid ""
"Lutris helps you install and play video games from all eras and from most "
"gaming systems. By leveraging and combining existing emulators, engine re-"
"implementations and compatibility layers, it gives you a central interface "
"to launch all your games."
msgstr ""
"Lutris facilita instalar e xogar a videoxogos de todas as épocas e case "
"calquera sistema. Proporciona unha interface centralizada para lanzar "
"tódolos teus xogos aproveitando e combinando emuladores existentes, "
"reimplementacións de motores e capas de compatibilidade."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:34
msgid "Add GOG depot-based downloads via gogdl integration"
msgstr ""
"Engadida descarga baseada en GOG depot a través da integración de gogdl"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:35
msgid "Add GOG cloud save synchronization"
msgstr "Engadida sincronización de gardado na nube de GOG"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:36
msgid "Add Playtron import"
msgstr "Engadida importación Playtron"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:37
msgid "Add parallel GOG download connections with resume support"
msgstr ""
"Engadida descarga de GOG con conexións en paralelo e soporte de continuación"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:38
msgid "Replace google-protobuf dependency with custom decoder for Battle.net"
msgstr ""
"Substituída a dependencia de google-protobuf por un decodificador propio "
"para Battle.net"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:39
msgid "Improve Humble Bundle authentication and error handling"
msgstr "Mellorada a autenticación e control de erros de Humble Bundle"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:40
msgid "Improve EA App auth handling and logo compositing"
msgstr ""
"Mellorada a xestión da autenticación na app de EA e a composición do logotipo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:41
msgid "Lazy-load libretro cores and MAME systems to avoid UI stalls"
msgstr ""
"Carga preguiceira dos núcleos de libretro e sistemas de MAME para evitar a "
"conxelación da IU"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:42
msgid "Fix itch.io ARM vs x86 upload selection"
msgstr "Corrixida a selección de carga ARM vs x86 en itch.io"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:43
msgid "Fix $RESOLUTION on KDE/Wayland with fractional scaling"
msgstr "Corrixida $RESOLUTION en KDE/Wayland con escalado fraccionado"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:44
msgid "Fix GPU detection in Flatpak"
msgstr "Corrixida a detección de GPU en Flatpak"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:45
msgid "Fix crash when closing Add Games dialog with Escape"
msgstr ""
"Corrixida caída do programa ao pechar o diálogo de \\\"Engadir xogos\\ con "
"Escape"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:46
msgid "Fix optional libretro firmware incorrectly treated as required"
msgstr ""
"Corrixido tratamento incorrecto como requirido do microprograma opcional de "
"libretro"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:47
msgid "Fix favorites view not updating when removing a game from favorites"
msgstr ""
"Corrixida vista de favoritos sen actualizarse ao quitar un xogo de favoritos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:48
msgid "Performance improvements for large game libraries"
msgstr "Mellora de rendemento en bibliotecas de xogos grandes"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:49
msgid "Updated pt_BR translation"
msgstr "Actualizada a tradución ao pt_BR"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:56
msgid "Fix type annotations requiring quoting for Python < 3.14 compatibility"
msgstr ""
"Corrixidas anotacións de tipos que necesitaban entrecomillado para "
"compatibilidade con Python < 3.14"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:57
msgid "Add mypy typing annotations on util/strings.py"
msgstr "Engadidas anotacións de tipos mypy en util/strings.py"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:58
msgid "Update release targets in PPA CI"
msgstr "Actualizados os obxectivos de publicación en PPA CI"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:65
msgid ""
"Add Sniper runtime support — runners can execute inside Valve's Sniper "
"container (Steam Linux Runtime 3.0)"
msgstr ""
"Engadido soporte de tempo de execución Sniper; os executores poden "
"executarse dentro dun contedor Sniper de Valve (Steam Linux Runtime 3.0)"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:66
msgid "Add ShadPS4 runner"
msgstr "Engadido o executor ShadPS4"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:67
msgid "Add Xenia runner"
msgstr "Engadido o executor Xenia"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:68
msgid "Dolphin-emu runner updated to use AppImage"
msgstr "Actualizado o executor do emulador Dolphin para usar AppImage"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:69
msgid "Add collapsible sidebar sections"
msgstr "Engadidas seccións pregables na barra lateral"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:70
msgid "Provide a sort for uncategorized games"
msgstr "Ofrecer ordenación para os xogos sen categorizar"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:71
msgid "Fallback icons for sidebar buttons when icon theme is missing them"
msgstr ""
"IIconas alternativas para os botóns da barra lateral cando o tema de iconas "
"non dispón deles"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:72
msgid "Add Python version to System Information"
msgstr "Engadida a versión de Python á información do sistema"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:73
msgid "Fix GPU UUID detection returning wrong GPU on multi-GPU systems"
msgstr ""
"Corrixido o problema polo que a detección de UUID de GPU devolvía unha GPU "
"incorrecta en sistemas multi-GPU"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:74
msgid ""
"Prefer most descriptive GPU name from vulkaninfo — fixes Intel Arc GPUs "
"reported as \"Intel Graphics\""
msgstr ""
"Preferir un nome máis descritivo para a GPU en vulkaninfo; corrixe cas GPUs "
"Intel Arc mostrásense como \\\"Intel Graphics\\\""

#: share/metainfo/net.lutris.Lutris.metainfo.xml:75
msgid "Add defensive check for vulkaninfo option lines with no \"=\""
msgstr "Engadida comprobación defensiva para liñas de vulkaninfo sen \\\"=\\\""

#: share/metainfo/net.lutris.Lutris.metainfo.xml:76
msgid "Fix ghost categories persisting after rename"
msgstr "Corrixidas categorías pantasma persistindo tras o seu renomeado"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:77
msgid "Fix sync_media returning attempted count instead of successful"
msgstr ""
"Corrixido o problema polo que sync_media devolvía o número de intentos en "
"lugar dos exitosos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:78
msgid "Fix VDF parser handling of escaped quotes"
msgstr "Corrixida a xestión das comiñas con escape no parser VDF"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:79
msgid "Fix Wine-Wayland warning — warns on Wayland only, not X11"
msgstr ""
"Corrixida a advertencia de Wine-Wayland; só advirte en Wayland e non en X11"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:80
msgid ""
"Add migration to move Proton versions from runners/proton to runners/wine"
msgstr ""
"Engadida migración para mover versións de Proton desde executores/proton a "
"executores/wine"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:81
msgid "Fix broken translations and add .po validation to CI"
msgstr ""
"Corrixidas traducións incorrectas e engadida validación de ficheiros .po ao "
"CI"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:82
msgid "Add Portuguese (Portugal) language support"
msgstr "Engadido soporte do portugués de Portugal"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:83
msgid "Update Spanish and French translations"
msgstr "Actualizadas as traducións de español e francés"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:90
msgid "Fix Ubisoft Connect login"
msgstr "Corrixida a conexión a Ubisoft Connect"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:91
msgid "Fix Battle.net source compatibility with newer protobuf versions"
msgstr ""
"Corrixida a compatibilidade da orixe Battle.net con novas versións de "
"protobuf"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:92
msgid ""
"Fix GOG installers for scripts using non-Windows runners (engine "
"reimplementations, etc.)"
msgstr ""
"Corrixidos instaladores de GOG que usan executores non-Windows "
"(reimplementacións de motores, etc.)"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:93
msgid "Fix compatibility with Python 3.14"
msgstr "Corrixida compatibilidade con Python 3.14"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:94
msgid "Fix Proton integration bugs so Proton-fixes are applied"
msgstr ""
"Corrixidos erros de integración de Proton de forma que se apliquen as "
"correccións de Proton"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:95
msgid ""
"Do not offer VKD3D, D3D Extras or DXVK-NVAPI on Proton versions; Proton will "
"handle these"
msgstr ""
"Non ofrecer as versións VKD3D, D3D Extras ou DXVK-NVAPI de Proton, isto "
"xestiónao o propio Proton"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:96
msgid ""
"The \"Enable Esync\" and \"Enable Fsync\" and \"DXVK\" settings are now "
"passed on to Proton"
msgstr ""
"As opcións \"Activar Esync\" e \"Activar Fsync\" e \"DXVK\" agora pásanse a "
"Proton"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:97
msgid "DXVK's integrated D8VK will be enabled in Proton"
msgstr "Actívase o D8VK integrado en DXVK en Proton"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:98
msgid "Wine runner adds an option to select Wine's \"Wayland driver\""
msgstr ""
"O executor Wine recibe unha opción para escoller o \"controlador Wayland\""

#: share/metainfo/net.lutris.Lutris.metainfo.xml:99
msgid ""
"Add little buttons to select cover-art, banner and icons via URL in game "
"configuration"
msgstr ""
"Engadidos pequenos botóns para escoller a portada, pancarta e iconas a "
"través dunha URL na configuración do xogo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:100
msgid ""
"Cover-art or banners from sources will be used when Lutris media is not "
"available"
msgstr ""
"Usaranse as portadas ou pancartas das orixes cando os medios de Lutris non "
"estean dispoñibles"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:101
msgid ""
"Emulator BIOS file location (used by libretro) may be set in Preferences"
msgstr ""
"A localización dos ficheiros de BIOS de emuladores (usados por libretro) "
"debe establecerse en Preferencias"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:102
msgid "Fix for updated Flathub API"
msgstr "Corrección na API actualizada de Flathub"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:103
msgid ""
"Change Itch.io over to the use of API keys instead of usernames and passwords"
msgstr ""
"Troco en Itch.io para usar claves de API en troques de nomes de usuario e "
"contrasinais"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:104
msgid "Update EA App source to their new API"
msgstr "Actualizado a orixe EA App á nova API"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:105
msgid ""
"Simplify Itch.io collections - if you have no collection named \"Lutris\", "
"we will show all games"
msgstr ""
"Simplificadas as coleccións de Itch.io - móstranse todos os xogos se non hai "
"unha colección chamada \"Lutris\""

#: share/metainfo/net.lutris.Lutris.metainfo.xml:106
msgid "MAME Machine setting uses a searchable entry for its enormous list"
msgstr "O axuste Máquina de MAME pódese buscar debido ao gran tamaño da lista"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:107
msgid "Obtain the release year from GOG and Itch.io"
msgstr "Obter o ano de lanzamento desde GOG e Itch.io"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:108
msgid "Add \"Azahar\" runner"
msgstr "Engadido o executor \"Azar\""

#: share/metainfo/net.lutris.Lutris.metainfo.xml:109
msgid "Add \"ZOOM Platform\" source"
msgstr "Engadida a orixe \"Plataforma ZOOM\""

#: share/metainfo/net.lutris.Lutris.metainfo.xml:110
msgid "Add \"Steam Family\" source to support Steam Families"
msgstr ""
"Engadido o orixe \"Familia de Steam\" para dar soporte a Familias de Steam"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:111
msgid ""
"Updated versions of runners for TIC-80, EasyRPG, mGBA, Rosalie's Mupen GUI, "
"Ruffle, 86Box"
msgstr ""
"Actualizadas as versións dos executores para TIC-80, EasyRPG, mGBA, "
"Rosalie's Mupen GUI, Ruffle, 86Box"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:112
msgid ""
"Ryujinx runner can now specify 'application ID' for your multi-game XCIs"
msgstr ""
"O executor Ryujinx agora pode especificar 'IDE de aplicación' para XCIs "
"multi-xogo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:113
msgid "Support for importing Commodore 64 ROMs"
msgstr "Soporte para importar ROMs de Commodore 64"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:114
msgid "Support ICDs for Intel Xe GPUs"
msgstr "Soporte para ICDs das GPUs Intel"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:115
msgid "Add option for 'ptyxis' terminal"
msgstr "Engadida opción para o terminal 'ptyxis'"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:116
msgid ""
"Redundant \"Add Games\" menu item removed; use the plus button in the corner"
msgstr ""
"Eliminada opción do menú \"Engadir xogos\" redundante; úsase o botón + da "
"esquina"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:117
msgid "Option to hide a source's games from also appearing in the Games view"
msgstr ""
"Opción para ocultar os xogos dunha orixe e que non aparezan na vista de Xogos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:118
msgid ""
"\"Manual Script\" for the context menu will now see the game's environment "
"variables"
msgstr ""
"\"Script manual\" no menú contextual agora amosa as variables de contorna do "
"xogo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:119
msgid "Add \"Create Steam Big Picture shortcut\" to the context menu"
msgstr ""
"Engadida opción \"Crear acceso directo a Steam Big Picture\" ao menú "
"contextual"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:120
msgid "Add a file association to run .lutris installer files via double-click"
msgstr ""
"Engadida asociación de ficheiro para executar os ficheiros de "
"instalador .lutris cun dobre-clic"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:127
msgid ""
"Lutris downloads the latest GE-Proton build for Wine if any Wine version is "
"installed"
msgstr ""
"Lutris descarga a última versión de GE-Proton para Wine se hai algunha "
"versión de Wine instalada"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:128
msgid "Use dark theme by default"
msgstr "Usar tema escuro de forma predeterminada"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:129
msgid "Display cover-art rather than banners by default"
msgstr "Amosar portadas en lugar de pancartas de forma predeterminada"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:130
msgid "Add 'Uncategorized' view to sidebar"
msgstr "Engadida vista 'Sen categorizar' ao panel lateral"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:131
msgid ""
"Preference options that do not work on Wayland will be hidden when on Wayland"
msgstr ""
"As opcións de preferencia que non funcionan en Wayland estarán ocultas cando "
"se estea en Wayland"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:132
msgid ""
"Game searches can now use fancy tags like 'installed:yes' or 'source:gog', "
"with explanatory tool-tip"
msgstr ""
"As procuras de xogos agora poden usar etiquetas avanzadas como "
"'installed:yes' ou 'source:gog', con información explicativa na xanela "
"emerxente"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:133
msgid ""
"A new filter button on the search box can build many of these fancy tags for "
"you"
msgstr ""
"Moitas destas etiquetas avanzadas poden crearse mediante un novo botón de "
"filtro no cadro de procura"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:134
msgid ""
"Runner searches can use 'installed:yes' as well, but no other fancy searches "
"or anything"
msgstr ""
"As procuras de executor tamén poden usar 'installed:yes', pero non outras "
"procuras avanzadas ou similar"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:135
msgid ""
"Updated the Flathub and Amazon source to new APIs, restoring integration"
msgstr ""
"Actualizáronse as orixes de Flathub e Amazon ás novas API, restablecendo a "
"integración"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:136
msgid ""
"Itch.io source integration will load a collection named 'Lutris' if present"
msgstr ""
"Se está presente, a integración coa orixe Itch.io cargará unha colección "
"chamada 'Lutris'"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:137
msgid ""
"GOG and Itch.io sources can now offer Linux and Windows installers for the "
"same game"
msgstr ""
"As plataformas GOG e Itch.io agora ofrecen instaladores para Linux e Windows "
"do mesmo xogo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:138
msgid "Added support for the 'foot' terminal"
msgstr "Engadiuse compatibilidade co terminal 'foot'"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:139
msgid "Support for DirectX 8 in DXVK v2.4"
msgstr "Compatibilidade con DirectX 8 en DXVK v2.4"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:140
msgid "Support for Ayatana Application Indicators"
msgstr "Compatibilidade para Indicadores de Aplicación Ayatana"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:141
msgid "Additional options for Ruffle runner"
msgstr "Opcións adicionais para o executor Ruffle"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:142
msgid "Updated download links for the Atari800 and MicroM8 runners"
msgstr ""
"Ligazóns de descarga actualizados para os executores Atari800 e MicroM8"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:143
msgid ""
"No longer re-download cached installation files even when some are missing"
msgstr ""
"Xa non se volverán a descargar os arquivos de instalación almacenados en "
"caché, mesmo se faltan algúns"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:144
msgid "Lutris log is included in the 'System' tab of the Preferences window"
msgstr ""
"O rexistro de Lutris inclúese na lapela 'Sistema' da xanela de Preferencias"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:145
msgid ""
"Improved error reporting, with the Lutris log included in the error details"
msgstr ""
"Informes de erros mellorados, co rexistro de Lutris incluído nos detalles do "
"erro"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:146
msgid "Add AppArmor profile for Ubuntu versions >= 23.10"
msgstr "Agregado perfil de AppArmor para versións de Ubuntu >= 23.10"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:147
msgid "Add Duckstation runner"
msgstr "Engadido o executor Duckstation"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:154
msgid ""
"Fix critical bug preventing completion of installs if the script specifies a "
"wine version"
msgstr ""
"Corrixido un erro crítico que impide completar as instalacións se o script "
"especifica unha versión concreta de wine"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:155
msgid "Fix critical bug preventing Steam library sync"
msgstr ""
"Corrixido un erro crítico que impide a sincronización coa biblioteca de Steam"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:156
msgid "Fix critical bug preventing game or runner uninstall in Flatpak"
msgstr ""
"Corrixido un erro crítico que impide desinstalar un xogo ou executor en "
"Flatpak"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:157
msgid "Support for library sync to lutris.net, this allows to sync games, play"
msgstr ""
"Soporte para sincronización de bibliotecas con lutris.net, isto permite "
"sincronizar xogos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:158
msgid "time and categories to multiple devices."
msgstr "tempos de xogo e categorías entre múltiples dispositivos."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:159
msgid ""
"Remove \"Lutris\" service view; with library sync the \"Games\" view "
"replaces it."
msgstr ""
"Eliminada a vista de servizo \"Lutris\" substituída pola vista \"Xogos\" coa "
"sincronización de biblioteca."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:160
msgid ""
"Torturous and sadistic options for multi-GPUs that were half broken and "
"understood by no one have been replaced by a simple GPU selector."
msgstr ""
"As opcións tortuosas e salvaxes para GPUs múltiples que estaban medio rotas "
"e ninguén entendía substituíronse por un simple selector de GPU."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:161
msgid ""
"EXPERIMENTAL support for umu, which allows running games with Proton and"
msgstr "Soporte EXPERIMENTAL para umu, que permite executar xogos con Proton e"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:162
msgid ""
"Pressure Vessel. Using Proton in Lutris without umu is no longer possible."
msgstr "Pressure Vessel. Xa non se pode usar Proton en Lutris sen umu."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:163
msgid ""
"Better and sensible sorting for games (sorting by playtime or last played no "
"longer needs to be reversed)"
msgstr ""
"Ordenación de xogos mellorada e máis razoable (xa non é necesario inverter a "
"ordenación por tempo de xogo ou última vez xogado)"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:164
msgid "Support the \"Categories\" command when you select multiple games"
msgstr ""
"Soporte para o comando \"Categorías\" cando seleccionas múltiples xogos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:165
msgid "Notification bar when your Lutris is no longer supported"
msgstr "Xa non se soporta a barra de notificación cando Lutris"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:166
msgid "Improved error dialog."
msgstr "Diálogo de erro mellorado."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:167
msgid "Add Vita3k runner (thanks @ItsAllAboutTheCode)"
msgstr "Engade o executor Vita3k (grazas @ltsAllAboutTheCode)"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:168
msgid "Add Supermodel runner"
msgstr "Engade o executor Supermodel"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:169
msgid "WUA files are now supported in Cemu"
msgstr "Cemu xa soporta arquivos WUA"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:170
msgid ""
"\"Show Hidden Games\" now displays the hidden games in a separate view, and "
"re-hides them as soon as you leave it."
msgstr ""
"\"Amosar xogos ocultos\" agora mostra os xogos ocultos nunha vista separada "
"e vólveos a ocultar ao abandonala."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:171
msgid "Support transparent PNG files for custom banner and cover-art"
msgstr ""
"Soporte de arquivos PNG transparentes para as pancartas personalizadas e as "
"portadas"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:172
msgid "Images are now downloaded for manually added games."
msgstr "Agora descárganse as imaxes dos xogos engadidos manualmente."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:173
msgid "Deprecate 'exe', 'main_file' or 'iso' placed at the root of the script,"
msgstr ""
"Desestímanse os arquivos 'exe', 'main_file' ou 'iso' colocados na raíz do "
"script,"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:174
msgid "all lutris.net installers have been updated accordingly."
msgstr "todos os instaladores de lutris.net actualizáronse en consecuencia."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:175
msgid "Deprecate libstrangle and xgamma support."
msgstr "Desestimado o soporte de libstrangle e xgamma."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:176
msgid ""
"Deprecate DXVK state cache feature (it was never used and is no longer "
"relevant to DXVK 2)"
msgstr ""
"Desestímase a funcionalidade de caché de estado de DXVK (xamais utilizada e "
"agora irrelevante para DXVK 2)"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:183
msgid "Fix bug that prevented installers to complete"
msgstr "Corrixido un erro que evitaba que se completasen as instalacións"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:184
msgid "Better handling of Steam configurations for the Steam account picker"
msgstr ""
"Mellor xestión das configuracións de Steam no selector de contas de Steam"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:185
msgid "Load game library in a background thread"
msgstr "Cargar a biblioteca de xogos noutro fío en segundo plano"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:192
msgid ""
"Fix some crashes happening when using Wayland and a high DPI gaming mouse"
msgstr ""
"Corrixidos algúns bloqueos que ocorrían cando se usaba Wayland e un rato "
"para xogos con alto DPI"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:193
msgid "Fix crash when opening the system preferences tab for a game"
msgstr ""
"Corrixido un fallo ao abrir a lapela de preferencias do sistema dun xogo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:194
msgid ""
"Reduced the locales list to a predefined one (let us know if you need yours "
"added)"
msgstr ""
"Reducida a lista de locais a unha predefinida (fáganos saber se precisa "
"engadir algún)"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:195
msgid "Fix Lutris not expanding \"~\" in paths"
msgstr "Corrixido que Lutris non expanda \"~\" nos roteiros"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:196
msgid "Download runtime components from the main window,"
msgstr ""
"Descarga os compoñentes en tempo de execución dende a xanela principal,"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:197
msgid ""
"the \"updating runtime\" dialog appearing before Lutris opens has been "
"removed"
msgstr ""
"eliminouse o diálogo \"actualizando tempo de execución\" que aparecía tras "
"abrir Lutris"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:198
msgid ""
"Add the ability to open a location in your file browser from file picker "
"widgets"
msgstr ""
"Engadida a posibilidade de abrir unha localización no seu xestor de arquivos "
"dende o selector de arquivos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:199
msgid ""
"Add the ability to select, remove, or stop multiple games in the Lutris "
"window"
msgstr ""
"Engadida a posibilidade de seleccionar, eliminar ou parar múltiples xogos na "
"xanela de Lutris"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:200
msgid ""
"Redesigned 'Uninstall Game' dialog now completely removes games by default"
msgstr ""
"Redeseñouse o diálogo 'Desinstalar xogo' para eliminar completamente os "
"xogos de forma predeterminada"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:201
msgid "Fix the export / import feature"
msgstr "Arranxada a funcionalidade de exportar / importar"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:202
msgid "Show an animation when a game is launched"
msgstr "Amosa unha animación cando se lanza un xogo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:203
msgid ""
"Add the ability to disable Wine auto-updates at the expense of losing support"
msgstr ""
"Engadida a posibilidade de desactivar as actualizacións automáticas de Wine "
"a expensas de perder o soporte"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:204
msgid "Add playtime editing in the game preferences"
msgstr "Engadida edición do tempo de xogo nas preferencias do xogo"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:205
msgid ""
"Move game files, runners to the trash instead of deleting them they are "
"uninstalled"
msgstr ""
"Move os arquivos do xogo e os executores á papeleira en lugar de eliminalos "
"cando se desinstalan"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:206
msgid ""
"Add \"Updates\" tab in Preferences control and check for updates and correct "
"missing media"
msgstr ""
"Engadida lapela \"Actualizacións\" en Preferencias para controlar e buscar "
"actualizacións e corrixir medios ausentes"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:207
msgid "in the 'Games' view."
msgstr "na vista 'Xogos'."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:208
msgid ""
"Add \"Storage\" tab in Preferences to control game and installer cache "
"location"
msgstr ""
"Engadida lapela \"Almacenamento\" en Preferencias para xestionar a "
"localización das cachés de xogo e instalador"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:209
msgid ""
"Expand \"System\" tab in Preferences with more system information but less "
"brown."
msgstr ""
"Ampliada a lapela \"Sistema\" en Preferencias con máis información do "
"sistema e menos marrón."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:210
msgid "Add \"Run Task Manager\" command for Wine games"
msgstr ""
"Engadido o comando \"Executar administrador de tarefas\" nos xogos de Wine"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:211
msgid "Add two new, smaller banner sizes for itch.io games."
msgstr ""
"Engadidos dous tamaños máis pequenos de pancarta para os xogos de itch.io."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:212
msgid ""
"Ignore Wine virtual desktop setting when using Wine-GE/Proton to avoid crash"
msgstr ""
"Ignorar a configuración de escritorio virtual de Wine ao usar Wine-GE/Proton "
"para evitar bloqueos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:213
msgid "Ignore MangoHUD setting when launching Steam to avoid crash"
msgstr ""
"Ignorar a configuración de MangoHUD cando se executa Steam para evitar "
"bloqueos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:214
msgid "Sync Steam playtimes with the Lutris library"
msgstr "Sincronizar os tempos de xogo de Steam coa biblioteca de Lutris"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:221
msgid "Add Steam account switcher to handle multiple Steam accounts"
msgstr "Engadido un selector de contas de Steam para xestionar varias delas"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:222
msgid "on the same device."
msgstr "no mesmo dispositivo."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:223
msgid "Add user defined tags / categories"
msgstr "Engadidas etiquetas / categorías definidas polo usuario"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:224
msgid "Group every API calls for runtime updates in a single one"
msgstr ""
"Agrupa nunha todas as chamadas ás API para actualizar os tempos de execución"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:225
msgid "Download appropriate DXVK and VKD3D versions based on"
msgstr "Descargar as versións de DXKV e VKD3D apropiadas baseándose nos"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:226
msgid "the available GPU PCI IDs"
msgstr "ide. PCI de GPU dispoñibles"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:227
msgid ""
"EA App integration. Your Origin games and saves can be manually imported"
msgstr ""
"Integración con EA App. Os xogos e partidas gardadas de Origin pódense "
"importar manualmente"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:228
msgid "from your Origin prefix."
msgstr "dende o teu prefixo de Origin."

#: share/metainfo/net.lutris.Lutris.metainfo.xml:229
msgid "Add integration with ScummVM local library"
msgstr "Engadida integración coa biblioteca local de ScummVM"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:230
msgid "Download Wine-GE updates when Lutris starts"
msgstr "Descargar as actualizacións de Wine-GE ao iniciar Lutris"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:231
msgid "Group GOG and Amazon download in a single progress bar"
msgstr "Agrupada a descarga de GOG e de Amazon nunha única barra de progreso"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:232
msgid "Fix blank login window on online services such as GOG or EGS"
msgstr ""
"Corrixida a xanela de inicio de sesión en branco en servizos en liña como "
"GOG ou EGS"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:233
msgid "Add a sort name field"
msgstr "Engadido un campo de nome para a ordenación"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:234
msgid "Yuzu and xemu now use an AppImage"
msgstr "Yuzu e xemu agora usan AppImage"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:235
msgid "Experimental support for Flatpak provided runners"
msgstr "Soporte experimental para executores proporcionados en Flatpak"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:236
msgid "Header-bar search for configuration options"
msgstr "Procura de opcións de configuración na barra de cabeceira"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:237
msgid "Support for Gamescope 3.12"
msgstr "Soporte para Gamescope 3.12"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:238
msgid "Missing games show an additional badge"
msgstr "Os xogos que faltan amosan un símbolo adicional"

#: share/metainfo/net.lutris.Lutris.metainfo.xml:239
msgid "Add missing dependency on python3-gi-cairo for Debian packages"
msgstr "Engadida dependencia ausente de python3-gi-cairo aos paquetes Debian"


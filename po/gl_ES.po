#, python-brace-format
msgid "WineHQ Devel ({})"
msgstr "WineHQ Devel ({})"

#: lutris/runners/wine.py:243
#, python-brace-format
msgid "WineHQ Staging ({})"
msgstr "WineHQ Staging ({})"

#: lutris/runners/wine.py:244
#, python-brace-format
msgid "Wine Development ({})"
msgstr "Wine Development ({})"

#: lutris/runners/wine.py:245
#, python-brace-format
msgid "System ({})"
msgstr "Sistema ({})"

#: lutris/runners/wine.py:250
msgid "GE-Proton (Latest)"
msgstr "GE-Proton (último)"

#: lutris/runners/wine.py:261
msgid "Runs Windows games"
msgstr "Executa xogos de Windows"

#: lutris/runners/wine.py:262
msgid "Wine"
msgstr "Wine"

#: lutris/runners/wine.py:263
msgid "Windows"
msgstr "Windows"

#: lutris/runners/wine.py:272
msgid "The game's main EXE file"
msgstr "O arquivo EXE principal do xogo"

#: lutris/runners/wine.py:279
msgid "Windows command line arguments used when launching the game"
msgstr "Argumentos da liña de comandos de Windows utilizados ao iniciar o xogo"

#: lutris/runners/wine.py:293 lutris/runners/xenia.py:37
msgid "Wine prefix"
msgstr "Prefixo de Wine"

#: lutris/runners/wine.py:296
msgid ""
"The prefix used by Wine.\n"
"It's a directory containing a set of files and folders making up a confined "
"Windows environment."
msgstr ""
"O prefixo utilizado por Wine.\n"
"É un directorio que contén un conxunto de arquivos e cartafoles que "
"conforman unha contorna Windows confinado."

#: lutris/runners/wine.py:304 lutris/runners/xenia.py:43
msgid "Prefix architecture"
msgstr "Arquitectura do prefixo"

#: lutris/runners/wine.py:306
msgid "32-bit"
msgstr "32-bit"

#: lutris/runners/wine.py:306 lutris/runners/xenia.py:44
msgid "64-bit"
msgstr "64-bit"

#: lutris/runners/wine.py:308
msgid "The architecture of the Windows environment"
msgstr "A arquitectura da contorna Windows"

#: lutris/runners/wine.py:313
msgid "Integrate system files in the prefix"
msgstr "Integrar arquivos do sistema no prefixo"

#: lutris/runners/wine.py:317
msgid ""
"Place 'Documents', 'Pictures', and similar files in your home folder, "
"instead of keeping them in the game's prefix. This includes some saved games."
msgstr ""
"Situar os cartafoles 'Documentos', 'Imaxes' e similares no teu cartafol "
"persoal en lugar de mantelas dentro do prefixo do xogo. Isto inclúe certas "
"partidas gardadas."

#: lutris/runners/wine.py:326
msgid "Wine version"
msgstr "Versión de Wine"

#: lutris/runners/wine.py:332
msgid ""
"The version of Wine used to launch the game.\n"
"Using the last version is generally recommended, but some games work better "
"on older versions."
msgstr ""
"A versión de Wine utilizada para lanzar o xogo.\n"
"En xeral recoméndase utilizar a última versión pero algúns xogos funcionan "
"mellor con versións anteriores."

#: lutris/runners/wine.py:339
msgid "Custom Wine executable"
msgstr "Executable personalizado de Wine"

#: lutris/runners/wine.py:342
msgid ""
"The Wine executable to be used if you have selected \"Custom\" as the Wine "
"version."
msgstr ""
"O executable de Wine que se utilizará seleccionou \"Personalizada\" como "
"versión de Wine."

#: lutris/runners/wine.py:346
msgid "Use system winetricks"
msgstr "Usar o winetricks do sistema"

#: lutris/runners/wine.py:350
msgid "Switch on to use /usr/bin/winetricks for winetricks."
msgstr "Usa /usr/bin/winetricks para winetricks."

#: lutris/runners/wine.py:355
msgid "Enable DXVK"
msgstr "Activar DXVK"

#: lutris/runners/wine.py:359
msgid "DXVK"
msgstr "DXVK"

#: lutris/runners/wine.py:362
msgid ""
"Use DXVK to increase compatibility and performance in Direct3D 11, 10 and 9 "
"applications by translating their calls to Vulkan."
msgstr ""
"Usa DXVK e VKD3D para incrementar compatibilidade e rendemento das "
"aplicacións Direct3D 11, 10 e 9 ao trasladar as chamadas a Vulkan."

#: lutris/runners/wine.py:370
msgid "DXVK version"
msgstr "Versión de DXVK"

#: lutris/runners/wine.py:383
msgid "Enable VKD3D"
msgstr "Activar VKD3D"

#: lutris/runners/wine.py:386
msgid "VKD3D"
msgstr "VKD3D"

#: lutris/runners/wine.py:389
msgid ""
"Use VKD3D to enable support for Direct3D 12 applications by translating "
"their calls to Vulkan."
msgstr ""
"Usar VKD3D para habilitar a compatibilidade con aplicacións Direct3D 12 "
"traducindo as súas chamadas a Vulkan."

#: lutris/runners/wine.py:394
msgid "VKD3D version"
msgstr "Versión de VKD3D"

#: lutris/runners/wine.py:406
msgid "Enable D3D Extras"
msgstr "Activar D3D Extras"

#: lutris/runners/wine.py:411
msgid ""
"Replace Wine's D3DX and D3DCOMPILER libraries with alternative ones. Needed "
"for proper functionality of DXVK with some games."
msgstr ""
"Substituír as librerías D3DX e D3DCOMPILER de Wine por outras alternativas. "
"É necesario para o correcto funcionamento de DXVK con algúns xogos."

#: lutris/runners/wine.py:418
msgid "D3D Extras version"
msgstr "Versión de D3D Extras"

#: lutris/runners/wine.py:428
msgid "Enable DXVK-NVAPI / DLSS"
msgstr "Activar DXVK-NVAPI / DLSS"

#: lutris/runners/wine.py:430
msgid "DXVK-NVAPI / DLSS"
msgstr "DXVK-NVAPI / DLSS"

#: lutris/runners/wine.py:434
msgid "Enable emulation of Nvidia's NVAPI and add DLSS support, if available."
msgstr ""
"Activa a emulación do NVAPI de Nvidia e engade soporte DLSS, se está "
"dispoñible."

#: lutris/runners/wine.py:439
msgid "DXVK NVAPI version"
msgstr "Versión de DXVK NVAPI"

#: lutris/runners/wine.py:450 lutris/sysoptions.py:269
msgid "Enable HDR (Experimental)"
msgstr "Activar HDR (experimental)"

#: lutris/runners/wine.py:456
msgid ""
"Enable Proton's support for High Dynamic Range graphics. Requires Wayland "
"selected as Graphics backend."
msgstr ""
"Activar o soporte de Proton para gráficos HDR. Require que Wayland estea "
"seleccionado como controlador gráfico."

#: lutris/runners/wine.py:462
msgid "Enable Esync"
msgstr "Activar Esync"

#: lutris/runners/wine.py:468
msgid ""
"Enable eventfd-based synchronization (esync). This will increase performance "
"in applications that take advantage of multi-core processors."
msgstr ""
"Activar a sincronización baseada en eventfd (esync). Aumentará o rendemento "
"nas aplicacións que aproveitan os procesadores multinúcleo."

#: lutris/runners/wine.py:475
msgid "Enable Fsync"
msgstr "Activar Fsync"

#: lutris/runners/wine.py:481
msgid ""
"Enable futex-based synchronization (fsync). This will increase performance "
"in applications that take advantage of multi-core processors. Requires "
"kernel 5.16 or above."
msgstr ""
"Activar a sincronización baseada en futex (fsync). Aumentará o rendemento "
"nas aplicacións que aproveitan os procesadores multinúcleo. Require un "
"kernel 5.16 ou superior."

#: lutris/runners/wine.py:489
msgid "Enable AMD FidelityFX Super Resolution (FSR)"
msgstr "Activar FidelityFX Super Resolution (FSR) de AMD"

#: lutris/runners/wine.py:493
msgid ""
"Use FSR to upscale the game window to native resolution.\n"
"Requires Lutris Wine FShack >= 6.13 and setting the game to a lower "
"resolution.\n"
"Does not work with games running in borderless window mode or that perform "
"their own upscaling."
msgstr ""
"Usar FSR para escalar a xanela do xogo á resolución nativa.\n"
"Require Lutris Wine FShack >= 6.13 e cambiar a unha resolución menor no "
"xogo.\n"
"Non funciona con xogos que se executan no modo de xanela sen bordos ou que "
"realizan o seu propio escalado."

#: lutris/runners/wine.py:500
msgid "Enable BattlEye Anti-Cheat"
msgstr "Activar anti-trampas BattlEye Anti-Cheat"

#: lutris/runners/wine.py:504
msgid ""
"Enable support for BattlEye Anti-Cheat in supported games\n"
"Requires Lutris Wine 6.21-2 and newer or any other compatible Wine build.\n"
msgstr ""
"Activa o soporte de BattlEye Anti-Cheat nos xogos co soportan\n"
"Require Lutris Wine 6.21-2 ou superior ou outra versión de Wine compatible.\n"

#: lutris/runners/wine.py:510
msgid "Enable Easy Anti-Cheat"
msgstr "Activar anti-trampas Easy Anti-Cheat"

#: lutris/runners/wine.py:514
msgid ""
"Enable support for Easy Anti-Cheat in supported games\n"
"Requires Lutris Wine 7.2 and newer or any other compatible Wine build.\n"
msgstr ""
"Activa o soporte de Easy Anti-Cheat nos xogos co soportan\n"
"Require Lutris Wine 7.2 ou superior ou outra versión de Wine compatible.\n"

#: lutris/runners/wine.py:520 lutris/runners/wine.py:535
msgid "Virtual Desktop"
msgstr "Escritorio Virtual"

#: lutris/runners/wine.py:521
msgid "Windowed (virtual desktop)"
msgstr "En xanela (escritorio virtual)"

#: lutris/runners/wine.py:528
msgid ""
"Run the whole Windows desktop in a window.\n"
"Otherwise, run it fullscreen.\n"
"This corresponds to Wine's Virtual Desktop option."
msgstr ""
"Executa todo o escritorio de Windows nunha xanela.\n"
"Se non, execútase en pantalla completa.\n"
"Corresponde coa opción de Escritorio Virtual de Wine."

#: lutris/runners/wine.py:536
msgid "Virtual desktop resolution"

msgstr "320×240 (4:3, orixinal)"

#: lutris/runners/easyrpg.py:311
msgid "416×240 (16:9, Widescreen)"
msgstr "416×240 (16:9, pantalla ancha)"

#: lutris/runners/easyrpg.py:312
msgid "560×240 (21:9, Ultrawide)"
msgstr "560×240 (21:9, ultra-ancho)"

#: lutris/runners/easyrpg.py:320
msgid "Scaling"
msgstr "Escalado"

#: lutris/runners/easyrpg.py:322
msgid ""
"How the video output is scaled.\n"
"\n"
"<b>Nearest</b>: Scale to screen size (causes scaling artifacts)\n"
"<b>Integer</b>: Scale to multiple of the game resolution\n"
"<b>Bilinear</b>: Like Nearest, but output is blurred to avoid artifacts\n"
msgstr ""
"Como se escala a saída de vídeo.\n"
"\n"
"<b>Máis próximo</b>: escalar ao tamaño de pantalla (causa artefactos de "
"escalado)\n"
"<b>Enteiro</b>: escalar a un múltiplo de la resolución do xogo\n"
"<b>Bilineal</b>: como \"Más próximo\", pero a saída difumínase para evitar "
"artefactos\n"

#: lutris/runners/easyrpg.py:328
msgid "Nearest"
msgstr "Más próximo"

#: lutris/runners/easyrpg.py:329
msgid "Integer"
msgstr "Enteiro"

#: lutris/runners/easyrpg.py:330
msgid "Bilinear"
msgstr "Bilineal"

#: lutris/runners/easyrpg.py:338 lutris/runners/redream.py:30
#: lutris/runners/scummvm.py:229
msgid "Stretch"
msgstr "Estender"

#: lutris/runners/easyrpg.py:339
msgid ""
"Ignore the aspect ratio and stretch video output to the entire width of the "
"screen."
msgstr ""
"Ignorar a relación de aspecto e estender a saída de vídeo á anchura completa "
"da pantalla."

#: lutris/runners/easyrpg.py:346
msgid "Enable VSync"
msgstr "Activar VSync"

#: lutris/runners/easyrpg.py:347
msgid "Switch off to disable VSync and use the FPS limit."
msgstr "Desmarcar para desactivar VSync e utilizar o límite de FPS."

#: lutris/runners/easyrpg.py:354
msgid "FPS limit"
msgstr "Límite de FPS"

#: lutris/runners/easyrpg.py:356
msgid ""
"Set a custom frames per second limit.\n"
"If unspecified, the default is 60 FPS.\n"
"Set to 0 to disable the frame limiter."
msgstr ""
"Establece un límite de fotogramas por segundo personalizado.\n"
"Se non se especifica, o valor predeterminado é 60 FPS.\n"
"Establecer a '0' para desactivar o limitador de fotogramas."

#: lutris/runners/easyrpg.py:368 lutris/runners/wine.py:631
msgid "Show FPS"
msgstr "Mostrar FPS"

#: lutris/runners/easyrpg.py:369
msgid "Enable frames per second counter."
msgstr "Activar o contador de fotogramas por segundo."

#: lutris/runners/easyrpg.py:372
msgid "Fullscreen & title bar"
msgstr "Pantalla completa e barra de título"

#: lutris/runners/easyrpg.py:373
msgid "Fullscreen, title bar & window"
msgstr "Pantalla completa, barra de título e xanela"

#: lutris/runners/easyrpg.py:380 lutris/runners/easyrpg.py:388
#: lutris/runners/easyrpg.py:395 lutris/runners/easyrpg.py:402
msgid "Runtime Package"
msgstr "Paquete do tempo de execución"

#: lutris/runners/easyrpg.py:381
msgid "Enable RTP"
msgstr "Activar RTP"

#: lutris/runners/easyrpg.py:382
msgid "Switch off to disable support for the Runtime Package (RTP)."
msgstr ""
"Desmarcar para desactivar a compatibilidade co paquete de tempo de execución "
"(RTP)."

#: lutris/runners/easyrpg.py:389
msgid "RPG2000 RTP location"
msgstr "Localización de RPG2000 RTP"

#: lutris/runners/easyrpg.py:390
msgid ""
"Full path to a directory containing an extracted RPG Maker 2000 Run-Time-"
"Package (RTP)."
msgstr ""
"Roteiro completo a un directorio que contén un paquete de tempo de execución "
"(RTP) de RPG Maker 2000 extraído."

#: lutris/runners/easyrpg.py:396
msgid "RPG2003 RTP location"
msgstr "Localización de RPG2003 RTP"

#: lutris/runners/easyrpg.py:397
msgid ""
"Full path to a directory containing an extracted RPG Maker 2003 Run-Time-"
"Package (RTP)."
msgstr ""
"Roteiro completo a un directorio que contén un paquete de tempo de execución "
"(RTP) de RPG Maker 2003 extraído."

#: lutris/runners/easyrpg.py:403
msgid "Fallback RTP location"
msgstr "Localización do RTP de reserva"

#: lutris/runners/easyrpg.py:404
msgid "Full path to a directory containing a combined RTP."
msgstr "Roteiro completo a un directorio que contén un RTP combinado."

#: lutris/runners/easyrpg.py:517
msgid "No game directory provided"
msgstr "Non se proporcionou ningún directorio de xogos"

#: lutris/runners/flatpak.py:21
msgid "Runs Flatpak applications"
msgstr "Executa aplicacións Flatpak"

#: lutris/runners/flatpak.py:24
msgid "Flatpak"
msgstr "Flatpak"

#: lutris/runners/flatpak.py:33 lutris/runners/ryujinx.py:31
#: lutris/runners/steam.py:37
msgid "Application ID"
msgstr "ID da aplicación"

#: lutris/runners/flatpak.py:34
msgid "The application's unique three-part identifier (tld.domain.app)."
msgstr "O identificador único en tres partes da aplicación (tld.dominio.apl)"

#: lutris/runners/flatpak.py:39
msgid "Architecture"
msgstr "Arquitectura"

#: lutris/runners/flatpak.py:41
msgid ""
"The architecture to run. See flatpak --supported-arches for architectures "
"supported by the host."
msgstr ""
"A arquitectura a executar. Consulta flatpak --supported-arches para ver as "
"arquitecturas compatibles co servidor."

#: lutris/runners/flatpak.py:45
msgid "Branch"
msgstr "Rama"

#: lutris/runners/flatpak.py:45
msgid "The branch to use."
msgstr "A rama a usar."

#: lutris/runners/flatpak.py:49
msgid "Install type"
msgstr "Tipo de instalación"

#: lutris/runners/flatpak.py:50
msgid "Can be system or user."
msgstr "Pode ser un sistema ou un usuario."

#: lutris/runners/flatpak.py:56
msgid "Args"
msgstr "Args"

#: lutris/runners/flatpak.py:57
msgid "Arguments to be passed to the application."
msgstr "Argumentos que pasar á aplicación."

#: lutris/runners/flatpak.py:62
msgid "Command"
msgstr "Comando"

#: lutris/runners/flatpak.py:63
msgid ""
"The command to run instead of the one listed in the application metadata."
msgstr ""
"O comando para executar en lugar do que aparece nos metadatos da aplicación."

#: lutris/runners/flatpak.py:71
msgid ""
"The directory to run the command in. Note that this must be a directory "
"inside the sandbox."
msgstr ""
"O directorio onde executar o comando. Teña en conta que debe ser un "
"directorio dentro da contorna illada."

#: lutris/runners/flatpak.py:77 lutris/sysoptions.py:460
msgid "Environment variables"
msgstr "Variables de contorna"

#: lutris/runners/flatpak.py:79
msgid ""
"Set an environment variable in the application. This overrides to the "
"Context section from the application metadata."
msgstr ""
"Establece unha variable de contorna na aplicación. Anula a sección Contexto "
"dos metadatos de aplicación."

#: lutris/runners/flatpak.py:92
msgid "The Flatpak executable could not be found."
msgstr "Non se puido atopar o executable Flatpak."

#: lutris/runners/flatpak.py:98
msgid ""
"Flatpak installation is not handled by Lutris.\n"
"Install Flatpak with the package provided by your distribution."
msgstr ""
"A instalación de Flatpak non está controlada por Lutris.\n"
"Instalar Flatpak usando o paquete proporcionado pola súa distribución."

#: lutris/runners/flatpak.py:140
msgid "No application specified."
msgstr "Non se especificou ningunha aplicación."

#: lutris/runners/flatpak.py:144
msgid ""
"Application ID is not specified in correct format.Must be something like: "
"tld.domain.app"
msgstr ""
"O ID de aplicación non está especificado no formato correcto. Debe ser algo "
"como: tld.dominio.apl"

#: lutris/runners/flatpak.py:148
msgid "Application ID field must not contain options or arguments."
msgstr "O campo de ID de aplicación non debe conter opcións nin argumentos."


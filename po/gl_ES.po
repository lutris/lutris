msgid "Debug"
msgstr "Depuración"

#: lutris/runners/easyrpg.py:144
msgid "Test play"
msgstr "Test play"

#: lutris/runners/easyrpg.py:145
msgid "Enable TestPlay (debug) mode."
msgstr "Activa o modo TestPlay (depuración)."

#: lutris/runners/easyrpg.py:153
msgid "Hide title"
msgstr "Ocultar o título"

#: lutris/runners/easyrpg.py:154
msgid "Hide the title background image and center the command menu."
msgstr "Ocultar a imaxe de fondo do título e centrar o menú de comandos."

#: lutris/runners/easyrpg.py:162
msgid "Start map ID"
msgstr "ID do mapa de inicio"

#: lutris/runners/easyrpg.py:164
msgid ""
"Overwrite the map used for new games and use MapXXXX.lmu instead.\n"
"Set to 0 to disable.\n"
"\n"
"Incompatible with 'Load game ID'."
msgstr ""
"Sobrescribir o mapa utilizado para as novas partidas e utilizar MapXXXX.lmu "
"no seu lugar.\n"
"Poñer a '0' para desactivalo. \n"
"\n"
"E incompatible con 'ID de carga de xogo'."

#: lutris/runners/easyrpg.py:177
msgid "Start position"
msgstr "Posición inicial"

#: lutris/runners/easyrpg.py:179
msgid ""
"Overwrite the party start position and move the party to the specified "
"position.\n"
"Provide two numbers separated by a space.\n"
"\n"
"Incompatible with 'Load game ID'."
msgstr ""
"Sobrescribir a posición de inicio do grupo e movelo á posición "
"especificada.\n"
"Proporcione dous números separados por un espazo. \n"
"\n"
"É incompatible con 'ID de carga de xogo'."

#: lutris/runners/easyrpg.py:189
msgid "Start party"
msgstr "Grupo inicial"

#: lutris/runners/easyrpg.py:191
msgid ""
"Overwrite the starting party members with the actors with the specified "
"IDs.\n"
"Provide one to four numbers separated by spaces.\n"
"\n"
"Incompatible with 'Load game ID'."
msgstr ""
"Sobrescribir os membros do grupo inicial cos actores cos IDs especificados.\n"
"Proporcione dun a catro números separados por espazos. \n"
"\n"
"É incompatible con 'ID de carga de xogo'."

#: lutris/runners/easyrpg.py:201
msgid "Battle test"
msgstr "Batalla de proba"

#: lutris/runners/easyrpg.py:202
msgid "Start a battle test with the specified monster party."
msgstr "Iniciar unha batalla de proba co grupo de monstros especificado."

#: lutris/runners/easyrpg.py:212
msgid "AutoBattle algorithm"
msgstr "Algoritmo de AutoBattle"

#: lutris/runners/easyrpg.py:214
msgid ""
"Which AutoBattle algorithm to use.\n"
"\n"
"<b>RPG_RT</b>: The default RPG_RT compatible algorithm, including RPG_RT "
"bugs.\n"
"<b>RPG_RT+</b>: The default RPG_RT compatible algorithm, with bug-fixes.\n"
"<b>ATTACK</b>: Like RPG_RT+ but only physical attacks, no skills."
msgstr ""
"Qué algoritmo usar para AutoBattle.\n"
"<b>RPG_RT</b>: algoritmo predeterminado compatible con RPG_RT, incluíndo os "
"seus fallos.\n"
"<b>RPG_RT+</b>: algoritmo predeterminado compatible con RPG_RT, sen os seus "
"fallos.\n"
"<b>ATTACK</b>: como RPG_RT+ pero só ataques físicos, sen habilidades."

#: lutris/runners/easyrpg.py:221 lutris/runners/easyrpg.py:240
msgid "RPG_RT"
msgstr "RPG_RT"

#: lutris/runners/easyrpg.py:222 lutris/runners/easyrpg.py:241
msgid "RPG_RT+"
msgstr "RPG_RT+"

#: lutris/runners/easyrpg.py:223
msgid "ATTACK"
msgstr "ATTACK"

#: lutris/runners/easyrpg.py:232
msgid "EnemyAI algorithm"
msgstr "Algoritmo de EnemyAI"

#: lutris/runners/easyrpg.py:234
msgid ""
"Which EnemyAI algorithm to use.\n"
"\n"
"<b>RPG_RT</b>: The default RPG_RT compatible algorithm, including RPG_RT "
"bugs.\n"
"<b>RPG_RT+</b>: The default RPG_RT compatible algorithm, with bug-fixes.\n"
msgstr ""
"Qué algoritmo usar para EnemyAI.\n"
"\n"
"<b>RPG_RT</b>: algoritmo predeterminado compatible con RPG_RT, incluindo os "
"seus fallos.\n"
"<b>RPG_RT+</b>: algoritmo predeterminado compatible con RPG_RT, sen os seus "
"fallos.\n"

#: lutris/runners/easyrpg.py:250
msgid "RNG seed"
msgstr "Semente RNG"

#: lutris/runners/easyrpg.py:251
msgid ""
"Seeds the random number generator.\n"
"Use -1 to disable."
msgstr ""
"Proporcionar unha semente ao xerador de números aleatorios (RNG).\n"
"Usar -1 para desactivala."


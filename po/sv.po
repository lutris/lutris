msgstr "Vinutveckling ({})"

#: lutris/runners/wine.py:183
#, python-brace-format
msgid "System ({})"
msgstr "System ({})"

#: lutris/runners/wine.py:188
msgid "GE-Proton (Latest)"
msgstr "GE-Proton (senaste versionen)"

#: lutris/runners/wine.py:199
msgid "Runs Windows games"
msgstr "Kör Windows-spel"

#: lutris/runners/wine.py:200
msgid "Wine"
msgstr "Vin"

#: lutris/runners/wine.py:201
msgid "Windows"
msgstr "Windows"

#: lutris/runners/wine.py:210
msgid "The game's main EXE file"
msgstr "Spelets huvudsakliga EXE-fil"

#: lutris/runners/wine.py:216
msgid "Windows command line arguments used when launching the game"
msgstr "Kommandoradsargument i Windows som används vid start av spelet"

#: lutris/runners/wine.py:230
msgid "Wine prefix"
msgstr "Vinmeny"

#: lutris/runners/wine.py:233
msgid ""
"The prefix used by Wine.\n"
"It's a directory containing a set of files and folders making up a confined Windows environment."
msgstr ""
"Prefixet som används av Wine.\n"
"Det är en katalog som innehåller en uppsättning filer och mappar som utgör en avgränsad Windows-miljö."

#: lutris/runners/wine.py:241
msgid "Prefix architecture"
msgstr "Prefixarkitektur"

#: lutris/runners/wine.py:242
msgid "32-bit"
msgstr "32-bitars"

#: lutris/runners/wine.py:242
msgid "64-bit"
msgstr "64-bitars"

#: lutris/runners/wine.py:244
msgid "The architecture of the Windows environment"
msgstr "Arkitekturen i Windows-miljön"

#: lutris/runners/wine.py:249
msgid "Integrate system files in the prefix"
msgstr "Integrera systemfiler i prefixet"

#: lutris/runners/wine.py:253
msgid ""
"Place 'Documents', 'Pictures', and similar files in your home folder, "
"instead of keeping them in the game's prefix. This includes some saved "
"games."
msgstr ""
"Placera \"Dokument\", \"Bilder\" och liknande filer i din hemmapp, istället "
"för att ha dem i spelets prefix. Detta inkluderar vissa sparade spel."

#: lutris/runners/wine.py:262
msgid "Wine version"
msgstr "Vinversion"

#: lutris/runners/wine.py:268
msgid ""
"The version of Wine used to launch the game.\n"
"Using the last version is generally recommended, but some games work better on older versions."
msgstr ""
"Den version av Wine som används för att starta spelet.\n"
"Att använda den senaste versionen rekommenderas i allmänhet, men vissa spel fungerar bättre med äldre versioner."

#: lutris/runners/wine.py:275
msgid "Custom Wine executable"
msgstr "Anpassad körbar fil för Wine"

#: lutris/runners/wine.py:278
msgid ""
"The Wine executable to be used if you have selected \"Custom\" as the Wine "
"version."
msgstr ""
"Den körbara Wine-filen som ska användas om du har valt \"Custom\" som Wine-"
"version."

#: lutris/runners/wine.py:282
msgid "Use system winetricks"
msgstr "Använd systemet winetricks"

#: lutris/runners/wine.py:286
msgid "Switch on to use /usr/bin/winetricks for winetricks."
msgstr "Aktivera /usr/bin/winetricks för att använda winetricks. "

#: lutris/runners/wine.py:291
msgid "Enable DXVK"
msgstr "Aktivera DXVK"

#: lutris/runners/wine.py:295
msgid "DXVK"
msgstr "DXVK"

#: lutris/runners/wine.py:298
msgid ""
"Use DXVK to increase compatibility and performance in Direct3D 11, 10 and 9 "
"applications by translating their calls to Vulkan."
msgstr ""
"Använd DXVK för att öka kompatibiliteten och prestandan i Direct3D 11-, 10- "
"och 9-program genom att översätta deras anrop till Vulkan."

#: lutris/runners/wine.py:306
msgid "DXVK version"
msgstr "DXVK-version"

#: lutris/runners/wine.py:319
msgid "Enable VKD3D"
msgstr "Aktivera VKD3D"

#: lutris/runners/wine.py:322
msgid "VKD3D"
msgstr "VKD3D"

#: lutris/runners/wine.py:325
msgid ""
"Use VKD3D to enable support for Direct3D 12 applications by translating "
"their calls to Vulkan."
msgstr ""
"Använd VKD3D för att aktivera stöd för Direct3D 12-program genom att "
"översätta deras anrop till Vulkan."

#: lutris/runners/wine.py:330
msgid "VKD3D version"
msgstr "VKD3D-versionen"

#: lutris/runners/wine.py:342
msgid "Enable D3D Extras"
msgstr "Aktivera D3D Extras"

#: lutris/runners/wine.py:347
msgid ""
"Replace Wine's D3DX and D3DCOMPILER libraries with alternative ones. Needed "
"for proper functionality of DXVK with some games."
msgstr ""
"Ersätt Wine's D3DX- och D3DCOMPILER-bibliotek med alternativa bibliotek. "
"Behövs för att DXVK ska fungera korrekt med vissa spel."

#: lutris/runners/wine.py:354
msgid "D3D Extras version"
msgstr "D3D Extras-versionen"

#: lutris/runners/wine.py:364
msgid "Enable DXVK-NVAPI / DLSS"
msgstr "Aktivera DXVK-NVAPI / DLSS"

#: lutris/runners/wine.py:366
msgid "DXVK-NVAPI / DLSS"
msgstr "DXVK-NVAPI / DLSS"

#: lutris/runners/wine.py:370
msgid "Enable emulation of Nvidia's NVAPI and add DLSS support, if available."
msgstr ""
"Aktivera emulering av Nvidias NVAPI och lägg till stöd för DLSS, om det "
"finns tillgängligt."

#: lutris/runners/wine.py:375
msgid "DXVK NVAPI version"
msgstr "DXVK NVAPI-version"

#: lutris/runners/wine.py:386
msgid "Enable dgvoodoo2"
msgstr "Aktivera dgvoodoo2"

#: lutris/runners/wine.py:391
msgid ""
"dgvoodoo2 is an alternative translation layer for rendering old games that "
"utilize D3D1-7 and Glide APIs. As it translates to D3D11, it's recommended "
"to use it in combination with DXVK. Only 32-bit apps are supported."
msgstr ""
"dgvoodoo2 är ett alternativt översättningslager för rendering av gamla spel "
"som använder D3D1-7 och Glide API:er. Eftersom det översätter till D3D11 "
"rekommenderas det att använda det i kombination med DXVK. Endast "
"32-bitarsappar stöds."

#: lutris/runners/wine.py:399
msgid "dgvoodoo2 version"
msgstr "dgvoodoo2-versionen"

#: lutris/runners/wine.py:408
msgid "Enable Esync"
msgstr "Aktivera Esync"

#: lutris/runners/wine.py:414
msgid ""
"Enable eventfd-based synchronization (esync). This will increase performance"
" in applications that take advantage of multi-core processors."
msgstr ""
"Aktivera eventfd-baserad synkronisering (esync). Detta ökar prestandan i "
"program som utnyttjar processorer med flera kärnor."

#: lutris/runners/wine.py:421
msgid "Enable Fsync"
msgstr "Aktivera Fsync"

#: lutris/runners/wine.py:427
msgid ""
"Enable futex-based synchronization (fsync). This will increase performance "
"in applications that take advantage of multi-core processors. Requires "
"kernel 5.16 or above."
msgstr ""
"Aktivera futex-baserad synkronisering (fsync). Detta kommer att öka "
"prestandan i program som utnyttjar flerkärniga processorer. Kräver kernel "
"5.16 eller senare."

#: lutris/runners/wine.py:435
msgid "Enable AMD FidelityFX Super Resolution (FSR)"
msgstr "Aktivera AMD FidelityFX Super Resolution (FSR)"

#: lutris/runners/wine.py:439
msgid ""
"Use FSR to upscale the game window to native resolution.\n"
"Requires Lutris Wine FShack >= 6.13 and setting the game to a lower resolution.\n"
"Does not work with games running in borderless window mode or that perform their own upscaling."
msgstr ""
"Använd FSR för att skala upp spelfönstret till ursprunglig upplösning.\n"
"Kräver Lutris Wine FShack >= 6.13 och att spelet ställs in på en lägre upplösning.\n"
"Fungerar inte med spel som körs i gränslöst fönsterläge eller som utför sin egen uppskalning."

#: lutris/runners/wine.py:446
msgid "Enable BattlEye Anti-Cheat"
msgstr "Aktivera BattlEye Anti-Cheat"

#: lutris/runners/wine.py:450
msgid ""
"Enable support for BattlEye Anti-Cheat in supported games\n"
"Requires Lutris Wine 6.21-2 and newer or any other compatible Wine build.\n"
msgstr ""
"Aktivera stöd för BattlEye Anti-Cheat i spel som stöds\n"
"Kräver Lutris Wine 6.21-2 och nyare eller någon annan kompatibel Wine-byggnad.\n"

#: lutris/runners/wine.py:456
msgid "Enable Easy Anti-Cheat"
msgstr "Aktivera Easy Anti-Cheat"

#: lutris/runners/wine.py:460
msgid ""
"Enable support for Easy Anti-Cheat in supported games\n"
"Requires Lutris Wine 7.2 and newer or any other compatible Wine build.\n"
msgstr ""

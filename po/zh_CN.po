#: lutris/sysoptions.py:202 lutris/sysoptions.py:218
msgid "Display"
msgstr "显示"

#: lutris/sysoptions.py:136
msgid "GPU"
msgstr "GPU"

#: lutris/sysoptions.py:140
msgid "GPU to use to run games"
msgstr "运行游戏时使用的 GPU"

#: lutris/sysoptions.py:146
msgid "FPS counter (MangoHud)"
msgstr "显示帧率（MangoHud）"

#: lutris/sysoptions.py:149
msgid ""
"Display the game's FPS + other information. Requires MangoHud to be "
"installed."
msgstr "显示游戏的 FPS 和其他信息。需要安装MangoHud。"

#: lutris/sysoptions.py:155
msgid "Restore resolution on game exit"
msgstr "游戏退出时恢复分辨率"

#: lutris/sysoptions.py:160
msgid ""
"Some games don't restore your screen resolution when \n"
"closed or when they crash. This is when this option comes \n"
"into play to save your bacon."
msgstr ""
"某些游戏在关闭或意外崩溃时无法恢复屏幕分辨率，启用这个选项让 Lutris 帮您恢"
"复。"

#: lutris/sysoptions.py:168
msgid "Disable desktop effects"
msgstr "禁用桌面特效"

#: lutris/sysoptions.py:174
msgid ""
"Disable desktop effects while game is running, reducing stuttering and "
"increasing performance"
msgstr "在游戏运行时禁用桌面特效（桌面合成），可减少卡顿、提高性能"

#: lutris/sysoptions.py:179
msgid "Prevent sleep"
msgstr "阻止睡眠"

#: lutris/sysoptions.py:184
msgid "Prevents the computer from suspending when a game is running."
msgstr "防止在游戏运行时让电脑进入休眠状态。"

#: lutris/sysoptions.py:190
msgid "SDL 1.2 Fullscreen Monitor"
msgstr "指定 SDL 1.2 程序使用的显示器"

#: lutris/sysoptions.py:196
msgid ""
"Hint SDL 1.2 games to use a specific monitor when going fullscreen by "
"setting the SDL_VIDEO_FULLSCREEN environment variable"
msgstr ""
"通过设置 SDL_VIDEO_FULLSCREEN 环境变量，让 SDL 1.2 游戏在进入全屏模式时使用特"
"定的显示器"

#: lutris/sysoptions.py:205
msgid "Turn off monitors except"
msgstr "关闭除指定显示器外的其他显示器"

#: lutris/sysoptions.py:211
msgid ""
"Only keep the selected screen active while the game is running. \n"
"This is useful if you have a dual-screen setup, and are \n"
"having display issues when running a game in fullscreen."
msgstr ""
"游戏运行时仅使选定的屏幕保持活动状态。\n"
"如果您有多块显示器，并且在全屏模式下运行游戏时出现显示问题，可以试试该选项。"

#: lutris/sysoptions.py:221
msgid "Switch resolution to"
msgstr "切换分辨率为"

#: lutris/sysoptions.py:226
msgid "Switch to this screen resolution while the game is running."
msgstr "在游戏运行时切换到此屏幕分辨率。"

#: lutris/sysoptions.py:232
msgid "Enable Gamescope"
msgstr "启用 gamescope"

#: lutris/sysoptions.py:235
msgid ""
"Use gamescope to draw the game window isolated from your desktop.\n"
"Toggle fullscreen: Super + F"
msgstr ""
"使用 gamescope 绘制与当前桌面隔离的游戏窗口。\n"
"可按 Super+F 组合键切换全屏与窗口模式。"

#: lutris/sysoptions.py:246
msgid ""
"Enable HDR for games that support it.\n"
"Requires Plasma 6 and VK_hdr_layer."
msgstr ""
"为支持 HDR 的游戏启用 HDR。\n"
"需要 Plasma 6 和 VK_hdr_layer。"

#: lutris/sysoptions.py:252
msgid "Relative Mouse Mode"
msgstr "相对鼠标模式"

#: lutris/sysoptions.py:258
msgid ""
"Always use relative mouse mode instead of flipping\n"
"dependent on cursor visibility\n"
"Can help with games where the player's camera faces the floor"
msgstr ""
"始终使用相对鼠标模式，而非根据光标可见性切换。\n"
"有助于解决玩家视角朝向地面的游戏中的问题。"

#: lutris/sysoptions.py:267
msgid "Output Resolution"
msgstr "输出分辨率"

#: lutris/sysoptions.py:273
msgid ""
"Set the resolution used by gamescope.\n"
"Resizing the gamescope window will update these settings.\n"
"\n"
"<b>Custom Resolutions:</b> (width)x(height)"
msgstr ""
"设置 gamescope 使用的分辨率。\n"
"调整 gamescope 窗口大小将更新这些设置。\n"
"\n"
"<b>自定义分辨率：</b>(宽)x(高)"

#: lutris/sysoptions.py:283
msgid "Game Resolution"
msgstr "游戏分辨率"

#: lutris/sysoptions.py:287
msgid ""
"Set the maximum resolution used by the game.\n"
"\n"
"<b>Custom Resolutions:</b> (width)x(height)"
msgstr ""
"设置游戏使用的最大分辨率。\n"
"\n"
"<b>自定义分辨率：</b>(宽)x(高)"

#: lutris/sysoptions.py:292
msgid "Window Mode"
msgstr "窗口模式"

#: lutris/sysoptions.py:296
msgid "Windowed"
msgstr "窗口化"

#: lutris/sysoptions.py:297
msgid "Borderless"
msgstr "无边框窗口模式"

#: lutris/sysoptions.py:302
msgid ""
"Run gamescope in fullscreen, windowed or borderless mode\n"
"Toggle fullscreen : Super + F"
msgstr ""
"以全屏、窗口化或无边框模式运行 gamescope\n"
"切换全屏：Super + F"

#: lutris/sysoptions.py:307
msgid "FSR Level"
msgstr "FSR 级别"

#: lutris/sysoptions.py:313
msgid ""
"Use AMD FidelityFX™ Super Resolution 1.0 for upscaling.\n"
"Upscaler sharpness from 0 (max) to 20 (min)."
msgstr ""
"使用 AMD FidelityFX™ 超分辨率 1.0 进行放大。\n"
"放大锐度范围从 0（最锐利）到 20（最柔和）。"

#: lutris/sysoptions.py:319
msgid "Framerate Limiter"
msgstr "帧率限制"

#: lutris/sysoptions.py:324
msgid "Set a frame-rate limit for gamescope specified in frames per second."
msgstr "为 gamescope 设置帧率限制，单位为帧每秒。"

#: lutris/sysoptions.py:329
msgid "Custom Settings"
msgstr "自定义设置"

#: lutris/sysoptions.py:335
msgid ""
"Set additional flags for gamescope (if available).\n"
"See 'gamescope --help' for a full list of options."
msgstr ""
"设置 gamescope 的附加标志（如果可用）。\n"
"查看 'gamescope --help' 获取完整的选项列表。"

#: lutris/sysoptions.py:342
msgid "Restrict number of cores used"
msgstr "限制 CPU 核数"

#: lutris/sysoptions.py:344
msgid "Restrict the game to a maximum number of CPU cores."
msgstr "限制游戏可用的最大 CPU 核数。"

#: lutris/sysoptions.py:350
msgid "Restrict number of cores to"
msgstr "最大可用核数"

#: lutris/sysoptions.py:353
msgid ""
"Maximum number of CPU cores to be used, if 'Restrict number of cores used' "
"is turned on."
msgstr ""
"如果启用了“限制 CPU 核数”，则在此处设置要使用的最大 CPU 核数，默认为 1（单"
"核）。"

#: lutris/sysoptions.py:361
msgid "Enable Feral GameMode"
msgstr "启用游戏性能优先模式"

#: lutris/sysoptions.py:362
msgid "Request a set of optimisations be temporarily applied to the host OS"
msgstr ""
"在游戏运行时，请求将一组优化临时应用于主机 Linux 操作系统，以提升游戏性能"

#: lutris/sysoptions.py:368
msgid "Reduce PulseAudio latency"
msgstr "减少 PulseAudio 延迟"

#: lutris/sysoptions.py:372
msgid ""
"Set the environment variable PULSE_LATENCY_MSEC=60 to improve audio quality "
"on some games"
msgstr "设置环境变量 PULSE_LATENCY_MSEC=60 以提高某些游戏的音频质量"

#: lutris/sysoptions.py:375 lutris/sysoptions.py:385 lutris/sysoptions.py:393
msgid "Input"
msgstr "输入"

#: lutris/sysoptions.py:378
msgid "Switch to US keyboard layout"
msgstr "切换到美式键盘布局"

#: lutris/sysoptions.py:382
msgid "Switch to US keyboard QWERTY layout while game is running"
msgstr "游戏运行时切换到美式键盘 QWERTY 布局"

#: lutris/sysoptions.py:388
msgid "AntiMicroX Profile"
msgstr "AntiMicroX 配置"

#: lutris/sysoptions.py:390
msgid "Path to an AntiMicroX profile file"
msgstr "AntiMicroX 配置文件的路径"

#: lutris/sysoptions.py:396
msgid "SDL2 gamepad mapping"
msgstr "SDL2 游戏手柄映射"

#: lutris/sysoptions.py:399
msgid ""
"SDL_GAMECONTROLLERCONFIG mapping string or path to a custom "
"gamecontrollerdb.txt file containing mappings."
msgstr ""
"SDL_GAMECONTROLLERCONFIG 映射字符串或包含映射的自定义 gamecontrollerdb.txt 文"
"件路径。"

#: lutris/sysoptions.py:403 lutris/sysoptions.py:415
msgid "Text based games"
msgstr "基于文本的游戏"

#: lutris/sysoptions.py:405
msgid "CLI mode"
msgstr "CLI模式"

#: lutris/sysoptions.py:410
msgid ""
"Enable a terminal for text-based games. Only useful for ASCII based games. "
"May cause issues with graphical games."
msgstr ""
"为基于文本的游戏打开终端，仅对基于 ASCII 的游戏有用。可能会导致使用图形的游戏"
"出现问题。"

#: lutris/sysoptions.py:417
msgid "Text based games emulator"
msgstr "基于文本的游戏模拟器"

#: lutris/sysoptions.py:423
msgid ""
"The terminal emulator used with the CLI mode. Choose from the list of "
"detected terminal apps or enter the terminal's command or path."
msgstr ""
"设置要与文本模式一起启动的终端模拟器。从检测到的终端应用列表中选择，或者输入"
"终端的命令或路径。\n"
"注意：不能保证所有终端模拟器都与 Lutris 兼容。"

#: lutris/sysoptions.py:429 lutris/sysoptions.py:436 lutris/sysoptions.py:446
#: lutris/sysoptions.py:454 lutris/sysoptions.py:462 lutris/sysoptions.py:470
#: lutris/sysoptions.py:480 lutris/sysoptions.py:488 lutris/sysoptions.py:501
#: lutris/sysoptions.py:515
msgid "Game execution"
msgstr "游戏运行选项"

#: lutris/sysoptions.py:433
msgid "Environment variables loaded at run time"
msgstr "游戏运行时加载的环境变量"

#: lutris/sysoptions.py:439
msgid "Locale"
msgstr "区域设置"

#: lutris/sysoptions.py:443
msgid ""
"Can be used to force certain locale for an app. Fixes encoding issues in "
"legacy software."
msgstr "强制指定应用程序的某些区域设置，可用于修复旧版软件中的乱码问题。"

#: lutris/sysoptions.py:449
msgid "Command prefix"
msgstr "命令前缀"

#: lutris/sysoptions.py:451
msgid ""
"Command line instructions to add in front of the game's execution command."
msgstr "添加到游戏启动命令之前的命令行指令。"

#: lutris/sysoptions.py:457
msgid "Manual script"
msgstr "维护脚本"

#: lutris/sysoptions.py:459
msgid "Script to execute from the game's contextual menu"
msgstr ""
"设置该选项后，游戏的右键菜单中将出现“执行维护脚本”菜单项，点击可快速执行该脚"
"本。"

#: lutris/sysoptions.py:465
msgid "Pre-launch script"
msgstr "预启动脚本"

#: lutris/sysoptions.py:467
msgid "Script to execute before the game starts"
msgstr "游戏开始前执行的脚本"

#: lutris/sysoptions.py:473
msgid "Wait for pre-launch script completion"
msgstr "等待预启动脚本完成"

#: lutris/sysoptions.py:477
msgid "Run the game only once the pre-launch script has exited"
msgstr "等待预启动脚本退出后才运行游戏"

#: lutris/sysoptions.py:483
msgid "Post-exit script"
msgstr "退出脚本"

#: lutris/sysoptions.py:485
msgid "Script to execute when the game exits"
msgstr "游戏退出时执行的脚本"

#: lutris/sysoptions.py:491
msgid "Include processes"
msgstr "包括进程"

#: lutris/sysoptions.py:494
msgid ""
"What processes to include in process monitoring. This is to override the "
"built-in exclude list.\n"
"Space-separated list, processes including spaces can be wrapped in quotation "
"marks."
msgstr ""
"指定进程监控要包括的进程。这会覆盖内置的排除列表。\n"
"用空格分隔的列表，名称包括空格的进程可以用引号引起来。\n"
"如果列表中的任一进程仍在运行，Lutris 就视为游戏仍在运行。"

#: lutris/sysoptions.py:504
msgid "Exclude processes"
msgstr "排除进程"

#: lutris/sysoptions.py:507
msgid ""
"What processes to exclude in process monitoring. For example background "
"processes that stick around after the game has been closed.\n"
"Space-separated list, processes including spaces can be wrapped in quotation "
"marks."
msgstr ""
"指定进程监控要排除的进程，例如在游戏关闭后仍然存在的后台进程。\n"
"用空格分隔的列表，名称包括空格的进程可以用引号引起来。\n"
"如果只有排除列表中的进程在运行，Lutris 就视为游戏已停止运行。"

#: lutris/sysoptions.py:518
msgid "Killswitch file"
msgstr "Killswitch 文件"

#: lutris/sysoptions.py:521
msgid ""
"Path to a file which will stop the game when deleted \n"
"(usually /dev/input/js0 to stop the game on joystick unplugging)"
msgstr ""
"设置一个文件，如果该文件被删除则停止游戏\n"
"（通常是 /dev/input/js0，用于在拔下摇杆时停止游戏）"

